---
import { render } from "astro:content";
import FriendCard from "@components/FriendCard.astro";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getActiveSpecEntry } from "@utils/content-utils";
import { getFriendsList } from "../data/friends";

const friendsPost = await getActiveSpecEntry("friends");
const friendsList = getFriendsList();
const { Content } = friendsPost ? await render(friendsPost) : { Content: null };
---

<MainGridLayout title="友链" description="一些朋友的网站与博客">
    <div class="card-base px-6 md:px-9 py-6">
        <div class="mb-6">
            <div class="text-3xl font-bold text-90 mb-2">友链</div>
            <div class="text-50">一些朋友的网站与博客</div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {friendsList.map((friend) => (
                <FriendCard friend={friend} />
            ))}
        </div>

        {Content && (
            <Markdown class="mt-8">
                <Content />
            </Markdown>
        )}
    </div>
</MainGridLayout>

---
import { Icon } from "astro-icon/components";
import type { FriendItem } from "../data/friends";

interface Props {
	friend: FriendItem;
}

const { friend } = Astro.props;

function getHostname(siteurl: string): string {
	try {
		return new URL(siteurl).hostname;
	} catch {
		return siteurl;
	}
}
---
<div class="card-base group relative overflow-hidden border border-black/10 dark:border-white/10">
    <div class="p-5">
        <div class="flex items-start gap-4 mb-4">
            <div class="w-16 h-16 rounded-xl overflow-hidden shrink-0 bg-[var(--btn-regular-bg)]">
                <img
                    src={friend.imgurl}
                    alt={friend.title}
                    class="w-full h-full object-cover transition duration-300 group-hover:scale-110"
                    loading="lazy"
                />
            </div>
            <div class="min-w-0 flex-1">
                <div class="font-bold text-xl text-90 truncate transition group-hover:text-[var(--primary)]">
                    {friend.title}
                </div>
                <a
                    href={friend.siteurl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-50 truncate block transition hover:text-[var(--primary)]"
                >
                    {getHostname(friend.siteurl)}
                </a>
            </div>
        </div>

        <div class="text-sm text-75 leading-6 min-h-[3rem] line-clamp-2 mb-4">
            {friend.desc}
        </div>

        <div class="flex flex-wrap gap-2 mb-4">
            {friend.tags.map((tag) => (
                <span class="text-xs px-2 py-1 rounded-md bg-[var(--btn-regular-bg)] text-[var(--btn-content)] font-medium">
                    {tag}
                </span>
            ))}
        </div>

        <a
            href={friend.siteurl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-regular rounded-lg h-10 px-4 font-medium active:scale-95 inline-flex gap-2"
        >
            <Icon name="fa6-solid:arrow-up-right-from-square" class="text-sm" />
            Visit
        </a>
    </div>

    <div class="absolute inset-0 opacity-0 pointer-events-none transition duration-300 bg-gradient-to-br from-[var(--primary)]/8 to-transparent group-hover:opacity-100"></div>
</div>
